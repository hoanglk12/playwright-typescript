<node id="tech-debt">
  <data key="d0">tech-debt</data>
  <data key="d1">method</data>
  <data key="d2">Tech debt refers to the accumulated debt in software development that arises from choosing an easy solution now instead of using a better approach that would take longer. It suggests that maintenance is required when major new features are added.</data>
  <data key="d3">doc-df9d885798e8423f552299c4f82dd919-chunk-001</data>
  <data key="d4">technical_debt_phase1.md</data>
  <data key="d5">1781592071</data>
  <data key="d6"></data>
</node>
