<node id="Serial Mode Rules">
  <data key="d0">Serial Mode Rules</data>
  <data key="d1">concept</data>
  <data key="d2">Guidelines that dictate how tests should be executed in terms of sequencing, especially regarding certain APIs and test dependencies.</data>
