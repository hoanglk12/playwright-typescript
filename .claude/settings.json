{
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit)",
      "Bash(npm list *)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright__browser_navigate",
      "mcp__atlassian__jira_get_issue",
      "mcp__atlassian__jira_get_issue_comments",
      "mcp__vercel__get_deployment",
      "mcp__vercel__list_deployments",
      "mcp__vercel__get_project",
      "mcp__vercel__list_projects",
      "mcp__vercel__get_runtime_logs",
      "mcp__vercel__web_fetch_vercel_url",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Bash(xargs grep *)",
      "Bash(npx prettier --write *)",
      "Bash(npx playwright test *)",
      "Bash(playwright-cli *)",
      "Bash(npx playwright-cli *)",
      "mcp__playwright-test__browser_verify_element_visible",
      "mcp__playwright-test__browser_verify_text_visible",
      "mcp__playwright-test__browser_verify_list_visible",
      "mcp__playwright-test__browser_verify_value",
      "mcp__playwright-test__browser_wait_for"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.js",
            "timeout": 10,
            "statusMessage": "Safety check..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/user-prompt-submit.js",
            "timeout": 15,
            "statusMessage": "Preparing context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const f=(j.tool_input||{}).file_path||'';if(f.endsWith('.ts')||f.endsWith('.tsx')){const {spawnSync}=require('child_process');spawnSync('npx',['prettier','--write',f],{stdio:'inherit'});}process.exit(0);})\" 2>/dev/null || true",
            "statusMessage": "Formatting code..."
          },
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const f=(j.tool_input||{}).file_path||'';const isYml=f.endsWith('.yml')||f.endsWith('.yaml');if(!isYml)process.exit(1);const {spawnSync}=require('child_process');const r=spawnSync('npx',['js-yaml',f],{encoding:'utf8'});if(r.status!==0){process.stdout.write(JSON.stringify({systemMessage:'YAML syntax error in '+f+':\\n'+(r.stderr||r.stdout)}));process.exit(2);}process.exit(0);})\" 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "YAML syntax check..."
          },
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const f=(j.tool_input||{}).file_path||'';if(f.endsWith('.spec.ts')){const {spawnSync}=require('child_process');const r=spawnSync('npx',['playwright','test',f,'--reporter=list','--project=chromium'],{stdio:'inherit'});if(r.status!==0)process.exit(2);}process.exit(0);})\"",
            "timeout": 300,
            "asyncRewake": true,
            "statusMessage": "Running related Playwright tests..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const cmd=(j.tool_input||{}).command||'';const isTest=/npm (run )?test|npx playwright test/.test(cmd);if(isTest)console.log(JSON.stringify({systemMessage:'Tests complete. Open report: npm run report'}));process.exit(0);})\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "output=$(npx tsc --noEmit 2>&1); rc=$?; echo \"$output\"; [ $rc -ne 0 ] && exit 2 || exit 0",
            "timeout": 60,
            "statusMessage": "Final TypeScript check...",
            "asyncRewake": true
          },
          {
            "type": "command",
            "command": "node scripts/sync-memory-to-vault.mjs 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Syncing memory vault..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const name=j.agent_name||'Sub-agent';const usage=j.usage||{};const tokens=usage.total_tokens?` (${usage.total_tokens.toLocaleString()} tokens)`:'';process.stdout.write(JSON.stringify({systemMessage:`${name} finished${tokens}.`}));process.exit(0);})\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use-failure.js",
            "timeout": 30,
            "statusMessage": "Diagnosing write failure..."
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-batch.js",
            "timeout": 90,
            "statusMessage": "Batch TypeScript check..."
          }
        ]
      }
    ]
  }
}
