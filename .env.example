# Copy this file to .env.testing / .env.staging / .env.production and fill in real values.
# Never commit files with real values — they are gitignored.
# In CI, all of these are injected via GitHub Environment secrets/vars (see .github/workflows/).

# --- Application URLs (GitHub Environment vars) ---
FRONTSITE_URL=
ADMIN_URL=
API_BASE_URL=

# --- Credentials (GitHub Environment secrets) ---
USER_NAME=
PASSWORD=
ADMIN_EMAIL=
ADMIN_PASSWORD=
GRA_TEST_PASSWORD=

# --- Database (GitHub Environment secrets/vars) ---
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- API (GitHub Environment secrets) ---
GRAPHQL_BASE_URL=
GRAPHQL_ENDPOINT=/graphql

# --- Infra tokens (GitHub Repository secrets — same across all envs) ---
# CLOUDFLARE_API_TOKEN=     (set in repo secrets, not per-env)
# CLOUDFLARE_ACCOUNT_ID=    (set in repo secrets)
# SLACK_WEBHOOK_URL=        (set in repo secrets)
# PERCY_TOKEN=              (set in repo secrets)

# --- Test behaviour (hardcoded defaults in environment.ts — override locally if needed) ---
# HEADLESS=true
# WORKERS=50%
# TIMEOUT=30000
# RETRIES=2
# SCREENSHOT_MODE=only-on-failure
# VIDEO_MODE=retain-on-failure
# TRACE_MODE=on-first-retry
