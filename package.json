{
  "name": "playwright-typescript-framework",
  "version": "13.7.2025",
  "description": "Playwright TypeScript framework converted from Maven hybrid framework",
  "author": "Hoang Pham",
  "license": "Hoang Pham - Senior Quality Engineer",
  "contact": "hoanglk12@gmail.com",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:headless": "cross-env HEADLESS=true playwright test",
    "test:ui": "playwright test --ui",
    "test:ui:headless": "cross-env HEADLESS=true playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:serial": "playwright test --workers=1",
    "test:simple": "playwright test --workers=1 --project=chromium",
    "test:simple:admin": "playwright test tests/admin --workers=1 --project=chromium",
    "test:simple:frontsite": "playwright test tests/frontsite --workers=1 --project=chromium",
    "test:simple:login": "playwright test tests/admin/login.spec.ts --workers=1 --project=chromium",
    "test:simple:headed": "playwright test --workers=1 --project=chromium --headed",
    "test:simple:debug": "playwright test --workers=1 --project=chromium --headed --debug",
    "test:parallel": "cross-env WORKERS=50% npm test",
    "test:parallel:max": "cross-env WORKERS=100% npm test",
    "test:parallel:all": "cross-env WORKERS=50% playwright test --project=chromium --project=firefox --project=webkit",
    "test:testing": "cross-env NODE_ENV=testing npm test",
    "test:staging": "cross-env NODE_ENV=staging npm test",
    "test:production": "cross-env NODE_ENV=production npm test",
    "test:percy": "dotenv -e .env.testing -- percy exec -- playwright test --workers=1 --project=chromium",
    "test:percy:testing": "dotenv -e .env.testing -- percy exec -- playwright test --workers=1 --project=chromium",
    "test:percy:staging": "dotenv -e .env.staging -- percy exec -- playwright test --workers=1 --project=chromium",
    "test:percy:smoke": "dotenv -e .env.testing -- percy exec -- playwright test tests/ecommerce/smoke --workers=1 --project=chromium",
    "test:percy:admin": "dotenv -e .env.testing -- percy exec -- playwright test tests/admin --workers=1 --project=chromium",
    "test:percy:login": "dotenv -e .env.testing -- percy exec -- playwright test tests/admin/login.spec.ts --workers=1 --project=chromium",
    "clean": "rimraf test-results api-results playwright-report api-report blob-report .auth lighthouse-reports .lighthouseci monocart-report monocart-api-report",
    "clean:api": "rimraf test-results/api api-results api-report",
    "report": "playwright show-report",
    "report:open": "npx playwright show-report --port 9323",
    "report:api": "npx playwright show-report api-report --port 9324",
    "report:monocart": "npx monocart show-report monocart-report/index.html",
    "report:monocart:api": "npx monocart show-report monocart-api-report/index.html",
    "test:api:testing": "cross-env NODE_ENV=testing playwright test --config=api.config.ts",
    "test:api": "playwright test --config=api.config.ts",
    "test:api:serial": "playwright test --config=api.config.ts --workers=1",
    "test:api:headed": "echo 'API tests do not require browser - running headless'",
    "test:api:debug": "playwright test --config=api.config.ts --debug",
    "test:api:ui": "cross-env NODE_ENV=testing playwright test --config=api.config.ts --ui",
    "test:api:booker": "cross-env NODE_ENV=testing playwright test tests/api/restful-booker.spec.ts --config=api.config.ts --workers=1",
    "test:api:device-booker": "cross-env NODE_ENV=testing playwright test tests/api/objects-crud.spec.ts --config=api.config.ts --workers=1",
    "install:browsers": "npx playwright install",
    "install:browsers:deps": "npx playwright install --with-deps",
    "codegen": "npx playwright codegen",
    "lint": "tsc --noEmit",
    "clean:install": "npm run clean && npm ci && npm run install:browsers",
    "docker:build": "docker build -t playwright-framework .",
    "docker:test": "docker-compose up --abort-on-container-exit --remove-orphans",
    "docker:test:chromium": "docker-compose run --rm playwright-chromium",
    "docker:test:firefox": "docker-compose run --rm playwright-firefox",
    "docker:test:webkit": "docker-compose run --rm playwright-webkit",
    "docker:test:api": "docker-compose run --rm playwright-api",
    "docker:test:parallel": "docker-compose up playwright-chromium playwright-firefox playwright-webkit --abort-on-container-exit --remove-orphans",
    "docker:dev": "docker-compose up playwright-dev -d",
    "docker:dev:shell": "docker-compose exec playwright-dev /bin/bash",
    "docker:dev:stop": "docker-compose stop playwright-dev",
    "docker:clean": "docker-compose down --volumes --remove-orphans && docker system prune -f",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose build --no-cache",
    "lhci:run": "lhci collect --config=lighthouserc.js && lhci upload --config=lighthouserc.js && lhci assert --config=lighthouserc.js",
    "lhci:collect": "lhci collect --config=lighthouserc.js",
    "lhci:upload": "lhci upload --config=lighthouserc.js",
    "lhci:assert": "lhci assert --config=lighthouserc.js"
  },
  "keywords": [
    "playwright",
    "typescript",
    "testing",
    "e2e",
    "api",
    "automation"
  ],
  "devDependencies": {
    "@lhci/cli": "^0.15.0",
    "@percy/cli": "^1.31.11",
    "@percy/playwright": "^1.1.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "md-to-pdf": "^5.2.5",
    "monocart-reporter": "^2.10.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
